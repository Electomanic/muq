song:
  tempo: 120
  time: "4/4"
tracks:
  piano:
    instrument: acoustic_grand_piano
    channel: 1
patterns:
  numeric_dur:
    bars:
      # Quintuplet eighths (5 per beat across 2 beats) + half note
      - - {note: C4, dur_beats: 0.4}
        - {note: D4, dur_beats: 0.4}
        - {note: E4, dur_beats: 0.4}
        - {note: F4, dur_beats: 0.4}
        - {note: G4, dur_beats: 0.4}
        - {note: A4, dur: h}
arrangement:
  - name: test
    patterns:
      piano: numeric_dur
