# test_chords.muq — Verify chord (simultaneous note) output.
# Tests: multiple notes at same beat, note arrays.
# Expected MIDI: 3-note chord at tick 0, then 4-note chord at beat 3.

song:
  title: Chords Test
  tempo: 120
  time: 4/4

tracks:
  piano:
    instrument: acoustic_grand_piano
    channel: 1

patterns:
  chords:
    bars:
      - - {note: [C4, E4, G4], dur: h, vel: 80}
        - {note: [C4, E4, G4, B4], dur: h, vel: 90}

arrangement:
  - name: main
    patterns:
      piano: chords
