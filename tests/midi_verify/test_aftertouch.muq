song:
  tempo: 120
  time: "4/4"
tracks:
  strings:
    instrument: string_ensemble_1
    channel: 1
patterns:
  aftertouch_test:
    bars:
      - - {beat: 1, note: [C4, E4, G4], dur: w, vel: 90}
        - {beat: 1, aftertouch: 0}
        - {beat: 2, aftertouch: 60}
        - {beat: 3, aftertouch: 100}
        - {beat: 4, aftertouch: 0}
arrangement:
  - name: test
    patterns:
      strings: aftertouch_test
