song:
  tempo: 120
  time: "4/4"
tracks:
  piano:
    instrument: acoustic_grand_piano
    channel: 1
patterns:
  beat_addressed:
    bars:
      # All beat-addressed: chord then sequential notes placed explicitly
      - - {beat: 1, note: [C4, E4, G4], dur: h}
        - {beat: 3, note: A4, dur: e}
        - {beat: 3.5, note: B4, dur: e}
        - {beat: 4, note: C5, dur: q}
arrangement:
  - name: test
    patterns:
      piano: beat_addressed
